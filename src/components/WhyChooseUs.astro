---
// WhyChooseUs.astro
const features = [
  "Premium Professional Products",
  "Award-Winning Stylists",
  "Personalized Consultations",
  "Relaxing Luxury Environment",
  "Latest Beauty Trends",
  "Client Satisfaction Focus"
];
---
<section class="py-24 bg-white overflow-hidden">
  <div class="container mx-auto px-6 lg:px-12 grid lg:grid-cols-2 gap-16 items-center">
    
    <!-- Left: Image -->
    <div class="relative h-[600px] rounded-2xl overflow-hidden shadow-2xl animate-fade-up">
      <img 
        src="https://images.unsplash.com/photo-1527799820374-dcf8d9d4a388?auto=format&fit=crop&q=80&w=1200" 
        alt="Relaxing salon environment" 
        class="w-full h-full object-cover"
      />
    </div>

    <!-- Right: Content -->
    <div class="animate-fade-up" style="transition-delay: 200ms;">
      <h2 class="text-4xl lg:text-5xl font-heading text-primary mb-10">What Makes Us Different</h2>
      
      <div class="space-y-6">
        {features.map((feature, idx) => (
          <div class="flex items-center gap-4 animate-fade-up" style={`transition-delay: ${(idx * 100) + 300}ms;`}>
            <div class="flex-shrink-0 w-12 h-12 rounded-full bg-secondary/20 flex items-center justify-center text-accent">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <p class="text-xl text-primary font-medium">{feature}</p>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>
