---
// Testimonials.astro
const reviews = [
  {
    text: "The attention to detail was incredible. My hair has never looked healthier.",
    author: "Ananya Sharma"
  },
  {
    text: "An absolute oasis of luxury. The staff made me feel like royalty.",
    author: "Priya Patel"
  },
  {
    text: "My bridal makeup was flawless. It lasted all day and looked stunning in photos.",
    author: "Riya Verma"
  },
  {
    text: "The color specialists here are magicians. They achieved the exact blonde I wanted.",
    author: "Neha Singh"
  },
  {
    text: "A truly premium experience from the moment you walk through the doors.",
    author: "Kriti Kapoor"
  },
  {
    text: "Best haircut I've ever had. Sophia really understands face shapes and hair textures.",
    author: "Meera Reddy"
  }
];
---
<section id="reviews" class="py-24 bg-white">
  <div class="container mx-auto px-6 lg:px-12">
    <div class="text-center mb-16 animate-fade-up">
      <h2 class="text-4xl lg:text-5xl font-heading text-primary mb-4">Client Reviews</h2>
      <p class="text-text-secondary text-lg max-w-2xl mx-auto">Hear what our lovely clients have to say.</p>
    </div>

    <!-- Desktop Grid -->
    <div class="hidden md:grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {reviews.map((review, idx) => (
        <div class="bg-bg-light p-8 rounded-2xl border border-border-light animate-fade-up" style={`transition-delay: ${idx * 100}ms;`}>
          <div class="text-accent text-xl mb-4">★★★★★</div>
          <p class="text-text-primary text-lg font-heading italic mb-6">"{review.text}"</p>
          <p class="text-text-secondary font-medium uppercase tracking-widest text-sm">— {review.author}</p>
        </div>
      ))}
    </div>

    <!-- Mobile layout (stack for simplicity instead of complex JS carousel for now, but keeping premium feel) -->
    <div class="md:hidden flex flex-col gap-6">
       {reviews.slice(0,3).map((review) => (
        <div class="bg-bg-light p-8 rounded-2xl border border-border-light">
          <div class="text-accent text-xl mb-4">★★★★★</div>
          <p class="text-text-primary text-lg font-heading italic mb-6">"{review.text}"</p>
          <p class="text-text-secondary font-medium uppercase tracking-widest text-sm">— {review.author}</p>
        </div>
      ))}
    </div>
  </div>
</section>
