---
// Footer.astro
---
<footer class="bg-primary text-white/80 pt-20 pb-8 border-t border-white/10">
  <div class="container mx-auto px-6 lg:px-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
      
      <!-- Brand -->
      <div class="animate-fade-up">
        <a href="/" class="text-3xl font-heading font-semibold text-secondary tracking-tight block mb-6">
          Aura Luxe
        </a>
        <p class="text-sm mb-6 max-w-xs leading-relaxed">
          Beauty Refined. Confidence Elevated. A luxury salon experience tailored exclusively for you.
        </p>
        <div class="flex gap-4">
          <!-- Social Icons placeholders -->
          <a href="#" class="w-10 h-10 rounded-full border border-white/20 flex items-center justify-center hover:bg-secondary hover:text-primary transition-colors hover:border-secondary">
            IG
          </a>
          <a href="#" class="w-10 h-10 rounded-full border border-white/20 flex items-center justify-center hover:bg-secondary hover:text-primary transition-colors hover:border-secondary">
            FB
          </a>
        </div>
      </div>

      <!-- Services -->
      <div class="animate-fade-up" style="transition-delay: 100ms;">
        <h4 class="text-white font-heading text-xl mb-6">Services</h4>
        <ul class="space-y-4 text-sm">
          <li><a href="#" class="hover:text-secondary transition-colors">Hair Styling</a></li>
          <li><a href="#" class="hover:text-secondary transition-colors">Coloring</a></li>
          <li><a href="#" class="hover:text-secondary transition-colors">Treatments</a></li>
          <li><a href="#" class="hover:text-secondary transition-colors">Bridal</a></li>
        </ul>
      </div>

      <!-- Quick Links -->
      <div class="animate-fade-up" style="transition-delay: 200ms;">
        <h4 class="text-white font-heading text-xl mb-6">Quick Links</h4>
        <ul class="space-y-4 text-sm">
          <li><a href="#" class="hover:text-secondary transition-colors">Home</a></li>
          <li><a href="#gallery" class="hover:text-secondary transition-colors">Gallery</a></li>
          <li><a href="#packages" class="hover:text-secondary transition-colors">Pricing</a></li>
          <li><a href="#reviews" class="hover:text-secondary transition-colors">Reviews</a></li>
          <li><a href="#contact" class="hover:text-secondary transition-colors">Contact</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div class="animate-fade-up" style="transition-delay: 300ms;">
        <h4 class="text-white font-heading text-xl mb-6">Contact</h4>
        <ul class="space-y-4 text-sm">
          <li class="flex items-start gap-3">
            <span class="text-secondary mt-1">📍</span>
            Noida, Uttar Pradesh<br/>India
          </li>
          <li class="flex items-center gap-3">
            <span class="text-secondary">📞</span>
            +91 98765 43210
          </li>
          <li class="flex items-center gap-3">
            <span class="text-secondary">✉️</span>
            hello@auraluxe.com
          </li>
        </ul>
      </div>

    </div>

    <div class="border-t border-white/10 pt-8 flex flex-col md:flex-row items-center justify-between text-xs animate-fade-up">
      <p>© 2026 Aura Luxe Salon. All Rights Reserved.</p>
      <div class="flex gap-4 mt-4 md:mt-0">
        <a href="#" class="hover:text-secondary transition-colors">Privacy Policy</a>
        <a href="#" class="hover:text-secondary transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
