---
// Team.astro
const team = [
  {
    name: "Sophia Martinez",
    role: "Creative Director",
    exp: "12 Years Experience",
    image: "https://images.unsplash.com/photo-1580618672591-eb180b1a973f?auto=format&fit=crop&q=80&w=600"
  },
  {
    name: "James Anderson",
    role: "Senior Stylist",
    exp: "Color Specialist",
    image: "https://images.unsplash.com/photo-1519085360753-af0119f7cbe7?auto=format&fit=crop&q=80&w=600"
  },
  {
    name: "Isabella Chen",
    role: "Hair Artist",
    exp: "Bridal Expert",
    image: "https://images.unsplash.com/photo-1502823403499-6ccfcf4fb453?auto=format&fit=crop&q=80&w=600"
  }
];
---
<section id="team" class="py-24 bg-bg-light">
  <div class="container mx-auto px-6 lg:px-12">
    <div class="text-center mb-16 animate-fade-up">
      <h2 class="text-4xl lg:text-5xl font-heading text-primary mb-4">Meet Our Experts</h2>
      <p class="text-text-secondary text-lg max-w-2xl mx-auto">Passionate professionals dedicated to bringing your vision to life.</p>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {team.map((member, idx) => (
        <div 
          class="group relative rounded-2xl overflow-hidden animate-fade-up hover-lift bg-white shadow-lg shadow-primary/5"
          style={`transition-delay: ${idx * 150}ms;`}
        >
          <div class="aspect-[4/5] overflow-hidden">
            <img 
              src={member.image} 
              alt={member.name} 
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
            />
          </div>
          <div class="p-6 text-center">
            <h3 class="text-2xl font-heading text-primary mb-1">{member.name}</h3>
            <p class="text-accent font-medium text-sm mb-3 uppercase tracking-wider">{member.role}</p>
            <div class="inline-block px-4 py-1.5 bg-bg-light rounded-full text-text-secondary text-sm">
              {member.exp}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
