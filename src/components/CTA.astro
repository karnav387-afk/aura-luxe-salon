---
// CTA.astro
---
<section id="contact" class="py-32 relative overflow-hidden bg-primary text-white text-center">
  <!-- Subtle background pattern or overlay can go here -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-primary-light/20 via-primary to-primary z-0"></div>
  
  <div class="container mx-auto px-6 lg:px-12 relative z-10 animate-fade-up">
    <h2 class="text-5xl lg:text-7xl font-heading mb-8">Ready To Transform Your Look?</h2>
    <p class="text-secondary/80 text-xl max-w-2xl mx-auto mb-12 leading-relaxed">
      Book your appointment today and discover the perfect balance of luxury, expertise and care.
    </p>
    
    <a href="#" class="book-btn inline-block px-10 py-5 bg-secondary text-primary text-lg font-medium rounded-full hover-scale shadow-2xl shadow-secondary/20 transition-all">
      Book Appointment
    </a>
  </div>
</section>
