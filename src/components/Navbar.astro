---
// Navbar.astro
---
<nav class="fixed w-full z-50 transition-all duration-300 py-4" id="navbar">
  <div class="container mx-auto px-6 lg:px-12 flex items-center justify-between">
    <a href="/" class="text-3xl font-heading font-semibold text-white tracking-tight transition-colors duration-300">
      Aura Luxe
    </a>

    <!-- Desktop Menu (visible on 1024px and above) -->
    <div class="hidden lg:flex items-center gap-8">
      {['Services', 'Gallery', 'Team', 'Packages', 'Reviews', 'Contact'].map((item) => (
        <a 
          href={`#${item.toLowerCase()}`} 
          class="text-sm font-medium text-white hover:text-accent transition-colors relative group duration-300"
        >
          {item}
          <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-accent transition-all duration-300 group-hover:w-full"></span>
        </a>
      ))}
    </div>

    <!-- CTA (visible on 1024px and above) -->
    <div class="hidden lg:block">
      <a href="#" class="book-btn px-6 py-2.5 bg-primary text-white text-sm font-medium rounded-full hover-scale inline-block shadow-lg shadow-primary/20 hover:shadow-primary/40 transition-all">
        Book Appointment
      </a>
    </div>

    <!-- Mobile Menu Button (visible below 1024px) -->
    <button 
      class="lg:hidden text-white focus:outline-none focus:ring-2 focus:ring-accent rounded p-1 transition-colors duration-300" 
      id="mobile-menu-btn" 
      aria-label="Toggle Menu"
      aria-expanded="false"
      aria-haspopup="dialog"
      aria-controls="mobile-menu-drawer"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
      </svg>
    </button>
  </div>
</nav>

<!-- Mobile Menu Overlay -->
<div 
  id="mobile-menu-overlay" 
  class="fixed inset-0 bg-slate-900/60 backdrop-blur-xs z-40 opacity-0 pointer-events-none transition-opacity duration-300"
></div>

<!-- Mobile Menu Drawer (visible below 1024px) -->
<div 
  id="mobile-menu-drawer" 
  class="fixed top-0 right-0 h-full w-full sm:w-[400px] bg-bg-light/95 backdrop-blur-lg border-l border-border-light/50 z-50 shadow-2xl transform translate-x-full transition-transform duration-300 ease-in-out flex flex-col justify-between"
  role="dialog"
  aria-modal="true"
  aria-label="Mobile Navigation Menu"
  aria-hidden="true"
>
  <!-- Drawer Header -->
  <div class="p-6 border-b border-border-light/40 flex items-center justify-between">
    <a href="/" class="text-2xl font-heading font-semibold text-primary tracking-tight">
      Aura Luxe
    </a>
    <button 
      id="mobile-menu-close-btn" 
      class="p-2 text-primary hover:text-accent rounded-full transition-colors focus:outline-none focus:ring-2 focus:ring-accent"
      aria-label="Close Menu"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Navigation Links -->
  <div class="px-6 py-8 flex flex-col gap-6 overflow-y-auto flex-grow">
    {['Services', 'Gallery', 'Team', 'Packages', 'Reviews', 'Contact'].map((item) => (
      <a 
        href={`#${item.toLowerCase()}`} 
        class="mobile-nav-link text-xl font-medium text-text-primary hover:text-accent transition-colors flex items-center justify-between group py-2 border-b border-border-light/20"
      >
        <span>{item}</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent opacity-0 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    ))}
  </div>

  <!-- CTA Button in Drawer -->
  <div class="p-6 border-t border-border-light/40">
    <a 
      href="#" 
      class="book-btn w-full text-center px-6 py-4 bg-primary text-white text-base font-semibold rounded-full hover-scale inline-block shadow-lg shadow-primary/20 hover:shadow-primary/40 transition-all"
    >
      Book Appointment
    </a>
  </div>
</div>

<script>
  // Add glass effect on scroll and transition text colors
  document.addEventListener('DOMContentLoaded', () => {
    const navbar = document.getElementById('navbar');
    const logo = navbar?.querySelector('a[href="/"]');
    const links = navbar?.querySelectorAll('a:not(.book-btn):not([href="/"])');
    const mobileBtn = document.getElementById('mobile-menu-btn');

    function updateNavbarStyles() {
      if (window.scrollY > 50) {
        navbar?.classList.add('glass-nav', 'py-3');
        navbar?.classList.remove('py-4');
        logo?.classList.add('text-primary');
        logo?.classList.remove('text-white');
        mobileBtn?.classList.add('text-primary');
        mobileBtn?.classList.remove('text-white');
        links?.forEach(link => {
          link.classList.add('text-text-primary');
          link.classList.remove('text-white');
        });
      } else {
        navbar?.classList.remove('glass-nav', 'py-3');
        navbar?.classList.add('py-4');
        logo?.classList.remove('text-primary');
        logo?.classList.add('text-white');
        mobileBtn?.classList.remove('text-primary');
        mobileBtn?.classList.add('text-white');
        links?.forEach(link => {
          link.classList.remove('text-text-primary');
          link.classList.add('text-white');
        });
      }
    }

    window.addEventListener('scroll', updateNavbarStyles);
    updateNavbarStyles(); // Run initially in case of refresh

    // Mobile Menu elements
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenuCloseBtn = document.getElementById('mobile-menu-close-btn');
    const mobileMenuOverlay = document.getElementById('mobile-menu-overlay');
    const mobileMenuDrawer = document.getElementById('mobile-menu-drawer');
    const mobileNavLinks = document.querySelectorAll('.mobile-nav-link');
    const mobileBookBtn = mobileMenuDrawer?.querySelector('.book-btn');

    function openMobileMenu() {
      if (!mobileMenuDrawer || !mobileMenuOverlay || !mobileMenuBtn) return;
      
      mobileMenuDrawer.classList.remove('translate-x-full');
      mobileMenuOverlay.classList.remove('opacity-0', 'pointer-events-none');
      mobileMenuOverlay.classList.add('opacity-100', 'pointer-events-auto');
      
      mobileMenuBtn.setAttribute('aria-expanded', 'true');
      mobileMenuDrawer.setAttribute('aria-hidden', 'false');
      
      document.body.classList.add('overflow-hidden');
      
      // Focus close button inside drawer for accessibility
      setTimeout(() => {
        mobileMenuCloseBtn?.focus();
      }, 50);
    }

    function closeMobileMenu() {
      if (!mobileMenuDrawer || !mobileMenuOverlay || !mobileMenuBtn) return;
      
      mobileMenuDrawer.classList.add('translate-x-full');
      mobileMenuOverlay.classList.remove('opacity-100', 'pointer-events-auto');
      mobileMenuOverlay.classList.add('opacity-0', 'pointer-events-none');
      
      mobileMenuBtn.setAttribute('aria-expanded', 'false');
      mobileMenuDrawer.setAttribute('aria-hidden', 'true');
      
      document.body.classList.remove('overflow-hidden');
      
      // Return focus to menu toggle button
      mobileMenuBtn.focus();
    }

    // Toggle menu
    mobileMenuBtn?.addEventListener('click', () => {
      const isExpanded = mobileMenuBtn.getAttribute('aria-expanded') === 'true';
      if (isExpanded) {
        closeMobileMenu();
      } else {
        openMobileMenu();
      }
    });

    // Close buttons and overlay
    mobileMenuCloseBtn?.addEventListener('click', closeMobileMenu);
    mobileMenuOverlay?.addEventListener('click', closeMobileMenu);

    // Close on link clicks
    mobileNavLinks.forEach(link => {
      link.addEventListener('click', () => {
        // Use a tiny delay to allow scroll-smooth to start before closing
        setTimeout(closeMobileMenu, 250);
      });
    });

    // Close on mobile book appointment button click and trigger booking modal
    mobileBookBtn?.addEventListener('click', (e) => {
      e.preventDefault();
      closeMobileMenu();
      window.dispatchEvent(new Event('openBookingModal'));
    });

    // Close on Escape key press
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        const isExpanded = mobileMenuBtn?.getAttribute('aria-expanded') === 'true';
        if (isExpanded) {
          closeMobileMenu();
        }
      }
    });

    // Focus Trap inside drawer for accessibility
    mobileMenuDrawer?.addEventListener('keydown', (e) => {
      if (e.key !== 'Tab') return;
      
      const focusableElements = mobileMenuDrawer.querySelectorAll('button, [href], input, select, textarea, [tabindex="0"]');
      if (focusableElements.length === 0) return;
      
      const firstElement = focusableElements[0] as HTMLElement;
      const lastElement = focusableElements[focusableElements.length - 1] as HTMLElement;
      
      if (e.shiftKey) { // Shift + Tab
        if (document.activeElement === firstElement) {
          lastElement.focus();
          e.preventDefault();
        }
      } else { // Tab
        if (document.activeElement === lastElement) {
          firstElement.focus();
          e.preventDefault();
        }
      }
    });
  });
</script>
