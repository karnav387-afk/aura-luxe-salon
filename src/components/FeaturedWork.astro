---
// FeaturedWork.astro
---
<section class="py-24 bg-primary text-white overflow-hidden">
  <div class="container mx-auto px-6 lg:px-12 grid lg:grid-cols-2 gap-16 items-center">
    
    <!-- Left Column: Content -->
    <div class="animate-fade-up">
      <h2 class="text-4xl lg:text-5xl font-heading mb-6">Creating Beautiful Transformations</h2>
      <p class="text-secondary/80 text-lg mb-10 max-w-md leading-relaxed">
        Every client is unique. Our expert stylists craft looks that complement personality, lifestyle and confidence.
      </p>
      <a href="#gallery" class="inline-flex items-center gap-2 px-8 py-4 bg-secondary text-primary font-medium rounded-full hover-scale shadow-xl shadow-secondary/10 transition-all">
        View Gallery
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
        </svg>
      </a>
    </div>

    <!-- Right Column: Images Grid -->
    <div class="grid grid-cols-2 gap-4 animate-fade-up" style="transition-delay: 200ms;">
      <div class="space-y-4 pt-12">
        <div class="relative rounded-2xl overflow-hidden group aspect-[4/5]">
          <img src="https://images.unsplash.com/photo-1522337660859-02fbefca4702?auto=format&fit=crop&q=80&w=800" alt="Hair styling" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
          <div class="absolute inset-0 bg-gradient-to-t from-primary/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        </div>
        <div class="relative rounded-2xl overflow-hidden group aspect-square">
          <img src="https://images.unsplash.com/photo-1492106087820-71f1a00d2b11?auto=format&fit=crop&q=80&w=800" alt="Hair color" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
          <div class="absolute inset-0 bg-gradient-to-t from-primary/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        </div>
      </div>
      <div class="space-y-4">
        <div class="relative rounded-2xl overflow-hidden group aspect-square">
          <img src="https://images.unsplash.com/photo-1595476108010-b4d1f10d5e43?auto=format&fit=crop&q=80&w=800" alt="Makeup" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
          <div class="absolute inset-0 bg-gradient-to-t from-primary/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        </div>
        <div class="relative rounded-2xl overflow-hidden group aspect-[4/5]">
          <img src="https://images.unsplash.com/photo-1519699047748-de8e457a634e?auto=format&fit=crop&q=80&w=800" alt="Bridal makeup" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
          <div class="absolute inset-0 bg-gradient-to-t from-primary/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        </div>
      </div>
    </div>
  </div>
</section>
