---
import Sidebar from '../components/admin/Sidebar.astro';
import Topbar from '../components/admin/Topbar.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Admin Dashboard</title>
    
    <!-- We'll reuse global css, but admin will primarily use Tailwind utility classes directly to remain isolated -->
    <link rel="stylesheet" href="/src/styles/global.css" />
    
    <script>
      // Initial Theme Check to avoid flash
      if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark')
      } else {
        document.documentElement.classList.remove('dark')
      }
    </script>
  </head>
  <body class="bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-slate-100 min-h-screen">
    
    <Sidebar />
    
    <div class="lg:ml-64 flex flex-col min-h-screen">
      <Topbar title={title} />
      
      <main class="flex-1 p-4 lg:p-8">
        <slot />
      </main>
    </div>

    <!-- Toast Container -->
    <div id="toast-container" class="fixed bottom-4 right-4 z-50 flex flex-col gap-2"></div>

    <!-- Lucide Icons initialization script -->
    <script>
      import { createIcons, icons } from 'lucide';
      
      // Initialize icons on DOM load
      document.addEventListener('DOMContentLoaded', () => {
        createIcons({ icons });
      });

      // Global Toast Notification Utility
      window.showToast = (message: string, type: 'success' | 'error' | 'info' = 'info') => {
        const container = document.getElementById('toast-container');
        if (!container) return;

        const toast = document.createElement('div');
        toast.className = `px-4 py-3 rounded-lg shadow-lg flex items-center gap-3 transform transition-all duration-300 translate-y-full opacity-0 max-w-sm w-full`;
        
        let iconHtml = '';
        if (type === 'success') {
          toast.classList.add('bg-green-50', 'text-green-800', 'border', 'border-green-200', 'dark:bg-green-900/30', 'dark:text-green-400', 'dark:border-green-800');
          iconHtml = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>`;
        } else if (type === 'error') {
          toast.classList.add('bg-red-50', 'text-red-800', 'border', 'border-red-200', 'dark:bg-red-900/30', 'dark:text-red-400', 'dark:border-red-800');
          iconHtml = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg>`;
        } else {
          toast.classList.add('bg-blue-50', 'text-blue-800', 'border', 'border-blue-200', 'dark:bg-blue-900/30', 'dark:text-blue-400', 'dark:border-blue-800');
          iconHtml = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>`;
        }

        toast.innerHTML = `
          <div class="flex-shrink-0">${iconHtml}</div>
          <div class="text-sm font-medium flex-1">${message}</div>
          <button class="flex-shrink-0 opacity-50 hover:opacity-100" onclick="this.parentElement.remove()">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </button>
        `;

        container.appendChild(toast);

        // Animate in
        requestAnimationFrame(() => {
          toast.classList.remove('translate-y-full', 'opacity-0');
        });

        // Remove after 3s
        setTimeout(() => {
          toast.classList.add('opacity-0');
          setTimeout(() => toast.remove(), 300);
        }, 3000);
      };
      
      // Global interface for TypeScript
      declare global {
        interface Window {
          toggleSidebar: () => void;
          showToast: (message: string, type?: 'success' | 'error' | 'info') => void;
        }
      }
    </script>
  </body>
</html>
