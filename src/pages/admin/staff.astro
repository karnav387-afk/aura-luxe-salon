---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Staff Management">
  <div class="flex items-center justify-between mb-6">
    <div class="relative w-full max-w-sm">
      <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400"></i>
      <input type="text" id="search-input" placeholder="Search staff..." class="w-full pl-10 pr-4 py-2 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 text-slate-900 dark:text-white focus:ring-2 focus:ring-primary focus:outline-none transition-shadow" />
    </div>
    <button onclick="openModal()" class="flex items-center gap-2 bg-primary text-white px-4 py-2 rounded-lg hover:bg-primary/90 transition-colors shadow-sm">
      <i data-lucide="plus" class="w-4 h-4"></i>
      <span>Add Staff Member</span>
    </button>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6" id="staff-grid">
    <!-- Loading state -->
    <div class="col-span-full py-12 text-center text-slate-500">
      <i data-lucide="loader-2" class="w-8 h-8 animate-spin mx-auto mb-4"></i>
      <p>Loading staff...</p>
    </div>
  </div>

  <!-- Staff Modal -->
  <div id="staff-modal" class="fixed inset-0 bg-slate-900/50 z-50 flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300">
    <div class="bg-white dark:bg-slate-900 rounded-xl shadow-2xl w-full max-w-lg mx-4 transform scale-95 transition-transform duration-300 modal-content overflow-hidden flex flex-col max-h-[90vh]">
      <div class="p-6 border-b border-slate-200 dark:border-slate-800 flex justify-between items-center">
        <h3 class="text-xl font-semibold text-slate-900 dark:text-white" id="modal-title">Add Staff Member</h3>
        <button type="button" onclick="closeModal()" class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-300">
          <i data-lucide="x" class="w-5 h-5"></i>
        </button>
      </div>
      
      <form id="staff-form" class="p-6 space-y-4 overflow-y-auto">
        <input type="hidden" id="staff-id" />
        <input type="hidden" id="staff-photo-url" />
        
        <!-- Photo Upload UI -->
        <div class="flex flex-col items-center justify-center mb-6">
          <div class="w-24 h-24 rounded-full bg-slate-100 dark:bg-slate-800 border-2 border-dashed border-slate-300 dark:border-slate-700 overflow-hidden relative group flex items-center justify-center mb-3">
            <img id="photo-preview" src="" class="w-full h-full object-cover hidden" />
            <i id="photo-icon" data-lucide="camera" class="w-8 h-8 text-slate-400 absolute"></i>
            <label class="absolute inset-0 bg-black/50 hidden group-hover:flex items-center justify-center cursor-pointer transition-all">
              <span class="text-white text-xs font-medium">Upload</span>
              <input type="file" id="staff-photo-input" accept="image/*" class="hidden" />
            </label>
          </div>
          <p class="text-xs text-slate-500" id="upload-status">Click to upload photo</p>
        </div>

        <div>
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Full Name</label>
          <input type="text" id="staff-name" required class="w-full px-3 py-2 rounded-lg border border-slate-200 dark:border-slate-700 bg-transparent text-slate-900 dark:text-white focus:ring-2 focus:ring-primary focus:outline-none" />
        </div>

        <div>
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Specialization (e.g. Color Specialist)</label>
          <input type="text" id="staff-spec" class="w-full px-3 py-2 rounded-lg border border-slate-200 dark:border-slate-700 bg-transparent text-slate-900 dark:text-white focus:ring-2 focus:ring-primary focus:outline-none" />
        </div>

        <div class="flex items-center gap-2 mt-4">
          <input type="checkbox" id="staff-active" checked class="rounded border-slate-300 text-primary focus:ring-primary w-4 h-4" />
          <label for="staff-active" class="text-sm text-slate-700 dark:text-slate-300">Active (Available for booking)</label>
        </div>
      </form>
      
      <div class="p-6 border-t border-slate-200 dark:border-slate-800 flex justify-end gap-3 bg-slate-50 dark:bg-slate-800/50">
        <button type="button" onclick="closeModal()" class="px-4 py-2 rounded-lg font-medium text-slate-700 dark:text-slate-300 hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors">Cancel</button>
        <button type="submit" form="staff-form" class="px-4 py-2 bg-primary text-white rounded-lg font-medium hover:bg-primary/90 transition-colors shadow-sm flex items-center gap-2">
          <i data-lucide="save" class="w-4 h-4"></i>
          Save Staff
        </button>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  import { supabase } from '../../lib/supabase';
  import { createIcons, icons } from 'lucide';

  let allStaff: any[] = [];

  const modal = document.getElementById('staff-modal')!;
  const modalContent = modal.querySelector('.modal-content')!;
  const form = document.getElementById('staff-form') as HTMLFormElement;
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const photoInput = document.getElementById('staff-photo-input') as HTMLInputElement;
  const photoPreview = document.getElementById('photo-preview') as HTMLImageElement;
  const photoIcon = document.getElementById('photo-icon')!;
  const uploadStatus = document.getElementById('upload-status')!;
  
  window.openModal = (id?: string) => {
    form.reset();
    photoPreview.src = '';
    photoPreview.classList.add('hidden');
    photoIcon.classList.remove('hidden');
    uploadStatus.textContent = 'Click to upload photo';
    document.getElementById('modal-title')!.textContent = id ? 'Edit Staff Member' : 'Add Staff Member';
    
    if (id) {
      const s = allStaff.find(x => x.id === id);
      if (s) {
        (document.getElementById('staff-id') as HTMLInputElement).value = s.id;
        (document.getElementById('staff-name') as HTMLInputElement).value = s.name;
        (document.getElementById('staff-spec') as HTMLInputElement).value = s.specialization || '';
        (document.getElementById('staff-active') as HTMLInputElement).checked = s.active;
        (document.getElementById('staff-photo-url') as HTMLInputElement).value = s.photo || '';
        
        if (s.photo) {
          photoPreview.src = s.photo;
          photoPreview.classList.remove('hidden');
          photoIcon.classList.add('hidden');
        }
      }
    } else {
      (document.getElementById('staff-id') as HTMLInputElement).value = '';
      (document.getElementById('staff-photo-url') as HTMLInputElement).value = '';
    }

    modal.classList.remove('opacity-0', 'pointer-events-none');
    modalContent.classList.remove('scale-95');
  };

  window.closeModal = () => {
    modal.classList.add('opacity-0', 'pointer-events-none');
    modalContent.classList.add('scale-95');
  };

  photoInput.addEventListener('change', async (e: Event) => {
    const file = (e.target as HTMLInputElement).files?.[0];
    if (!file) return;

    try {
      uploadStatus.textContent = 'Uploading...';
      const fileExt = file.name.split('.').pop();
      const fileName = `${Math.random()}.${fileExt}`;
      const filePath = `photos/${fileName}`;

      const { error: uploadError } = await supabase.storage
        .from('staff-photos')
        .upload(filePath, file);

      if (uploadError) throw uploadError;

      const { data } = supabase.storage.from('staff-photos').getPublicUrl(filePath);
      
      (document.getElementById('staff-photo-url') as HTMLInputElement).value = data.publicUrl;
      photoPreview.src = data.publicUrl;
      photoPreview.classList.remove('hidden');
      photoIcon.classList.add('hidden');
      uploadStatus.textContent = 'Uploaded successfully!';
    } catch (err: any) {
      console.error(err);
      uploadStatus.textContent = 'Upload failed';
      window.showToast('Failed to upload image', 'error');
    }
  });

  async function fetchStaff() {
    const { data, error } = await supabase
      .from('staff')
      .select('*')
      .order('created_at', { ascending: false });

    if (error) {
      window.showToast('Failed to load staff', 'error');
      return;
    }
    
    allStaff = data;
    renderGrid(data);
  }

  function renderGrid(data: any[]) {
    const grid = document.getElementById('staff-grid')!;
    grid.innerHTML = '';

    if (data.length === 0) {
      grid.innerHTML = `<div class="col-span-full py-12 text-center text-slate-500">No staff members found.</div>`;
      return;
    }

    data.forEach(s => {
      const activeStatus = s.active 
        ? `<div class="absolute top-4 right-4 w-3 h-3 bg-green-500 rounded-full border-2 border-white dark:border-slate-900" title="Active"></div>`
        : `<div class="absolute top-4 right-4 w-3 h-3 bg-slate-400 rounded-full border-2 border-white dark:border-slate-900" title="Inactive"></div>`;

      const avatar = s.photo 
        ? `<img src="${s.photo}" alt="${s.name}" class="w-full h-full object-cover" />`
        : `<div class="w-full h-full bg-primary/10 flex items-center justify-center text-primary text-2xl font-bold">${s.name.charAt(0)}</div>`;

      grid.innerHTML += `
        <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 overflow-hidden relative group">
          ${activeStatus}
          <div class="h-32 bg-slate-100 dark:bg-slate-800 w-full relative">
            <div class="absolute -bottom-10 left-1/2 -translate-x-1/2 w-20 h-20 rounded-full border-4 border-white dark:border-slate-900 overflow-hidden bg-white">
              ${avatar}
            </div>
          </div>
          <div class="pt-14 pb-6 px-6 text-center">
            <h3 class="font-semibold text-lg text-slate-900 dark:text-white">${s.name}</h3>
            <p class="text-sm text-slate-500 dark:text-slate-400 mb-4">${s.specialization || 'Stylist'}</p>
            
            <div class="flex items-center justify-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
              <button onclick="openModal('${s.id}')" class="px-3 py-1.5 text-xs font-medium bg-blue-50 text-blue-600 hover:bg-blue-100 dark:bg-blue-900/30 dark:text-blue-400 dark:hover:bg-blue-900/50 rounded-lg transition-colors">Edit</button>
              <button onclick="deleteStaff('${s.id}')" class="px-3 py-1.5 text-xs font-medium bg-red-50 text-red-600 hover:bg-red-100 dark:bg-red-900/30 dark:text-red-400 dark:hover:bg-red-900/50 rounded-lg transition-colors">Delete</button>
            </div>
          </div>
        </div>
      `;
    });
    
    createIcons({ icons });
  }

  searchInput.addEventListener('input', (e) => {
    const term = (e.target as HTMLInputElement).value.toLowerCase();
    const filtered = allStaff.filter(s => s.name.toLowerCase().includes(term) || (s.specialization && s.specialization.toLowerCase().includes(term)));
    renderGrid(filtered);
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const id = (document.getElementById('staff-id') as HTMLInputElement).value;
    const payload = {
      name: (document.getElementById('staff-name') as HTMLInputElement).value,
      specialization: (document.getElementById('staff-spec') as HTMLInputElement).value,
      active: (document.getElementById('staff-active') as HTMLInputElement).checked,
      photo: (document.getElementById('staff-photo-url') as HTMLInputElement).value || null,
    };

    try {
      if (id) {
        const { error } = await supabase.from('staff').update(payload).eq('id', id);
        if (error) throw error;
        window.showToast('Staff updated successfully', 'success');
      } else {
        const { error } = await supabase.from('staff').insert(payload);
        if (error) throw error;
        window.showToast('Staff created successfully', 'success');
      }
      closeModal();
      fetchStaff();
    } catch (err: any) {
      window.showToast(err.message || 'An error occurred', 'error');
    }
  });

  window.deleteStaff = async (id: string) => {
    if (!confirm('Are you sure you want to delete this staff member?')) return;
    try {
      const { error } = await supabase.from('staff').delete().eq('id', id);
      if (error) throw error;
      window.showToast('Staff member deleted', 'info');
      fetchStaff();
    } catch (err: any) {
      window.showToast(err.message, 'error');
    }
  };

  declare global {
    interface Window {
      deleteStaff: (id: string) => void;
    }
  }

  document.addEventListener('DOMContentLoaded', fetchStaff);
</script>
