---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Appointments">
  <div class="flex flex-col md:flex-row gap-4 mb-6">
    <div class="relative flex-1">
      <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400"></i>
      <input type="text" id="search-input" placeholder="Search customer, email or phone..." class="w-full pl-10 pr-4 py-2 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 text-slate-900 dark:text-white focus:ring-2 focus:ring-primary focus:outline-none transition-shadow" />
    </div>
    <div class="flex gap-2">
      <input type="date" id="filter-date" class="px-4 py-2 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 text-slate-900 dark:text-white focus:ring-2 focus:ring-primary focus:outline-none" />
      <select id="filter-status" class="px-4 py-2 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 text-slate-900 dark:text-white focus:ring-2 focus:ring-primary focus:outline-none">
        <option value="">All Statuses</option>
        <option value="pending">Pending</option>
        <option value="confirmed">Confirmed</option>
        <option value="completed">Completed</option>
        <option value="cancelled">Cancelled</option>
      </select>
    </div>
  </div>

  <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="bg-slate-50 dark:bg-slate-800/50 text-slate-500 dark:text-slate-400 text-sm border-b border-slate-200 dark:border-slate-800">
            <th class="p-4 font-medium">Customer Details</th>
            <th class="p-4 font-medium">Service & Staff</th>
            <th class="p-4 font-medium">Date & Time</th>
            <th class="p-4 font-medium">Status</th>
            <th class="p-4 font-medium">Payment Status</th>
            <th class="p-4 font-medium text-right">Actions</th>
          </tr>
        </thead>
        <tbody id="appointments-body" class="divide-y divide-slate-200 dark:divide-slate-800 text-slate-700 dark:text-slate-300">
          <tr>
            <td colspan="6" class="p-8 text-center text-slate-500">
              <i data-lucide="loader-2" class="w-6 h-6 animate-spin mx-auto"></i>
              <p class="mt-2 text-sm">Loading appointments...</p>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</AdminLayout>

<script>
  import { supabase } from '../../lib/supabase';
  import { createIcons, icons } from 'lucide';

  let allAppointments: any[] = [];
  
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const filterDate = document.getElementById('filter-date') as HTMLInputElement;
  const filterStatus = document.getElementById('filter-status') as HTMLSelectElement;

  async function fetchAppointments() {
    const { data, error } = await supabase
      .from('appointments')
      .select(`
        *,
        services (name),
        staff (name)
      `)
      .order('appointment_date', { ascending: false })
      .order('appointment_time', { ascending: false });

    if (error) {
      window.showToast('Failed to load appointments', 'error');
      return;
    }
    
    allAppointments = data;
    applyFilters();
  }

  function applyFilters() {
    const term = searchInput.value.toLowerCase();
    const date = filterDate.value;
    const status = filterStatus.value;

    const filtered = allAppointments.filter(a => {
      const matchSearch = a.customer_name.toLowerCase().includes(term) || 
                          (a.customer_email && a.customer_email.toLowerCase().includes(term)) ||
                          (a.customer_phone && a.customer_phone.includes(term));
      const matchDate = date ? a.appointment_date === date : true;
      const matchStatus = status ? a.status === status : true;
      
      return matchSearch && matchDate && matchStatus;
    });

    renderTable(filtered);
  }

  searchInput.addEventListener('input', applyFilters);
  filterDate.addEventListener('change', applyFilters);
  filterStatus.addEventListener('change', applyFilters);

  function renderTable(data: any[]) {
    const tbody = document.getElementById('appointments-body')!;
    tbody.innerHTML = '';

    if (data.length === 0) {
      tbody.innerHTML = `<tr><td colspan="6" class="p-8 text-center text-slate-500">No appointments found matching your criteria.</td></tr>`;
      return;
    }

    data.forEach(apt => {
      const statusColors: Record<string, string> = {
        'pending': 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-400 border-yellow-200 dark:border-yellow-800',
        'confirmed': 'bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-400 border-blue-200 dark:border-blue-800',
        'completed': 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400 border-green-200 dark:border-green-800',
        'cancelled': 'bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400 border-red-200 dark:border-red-800'
      };

      const paymentColors: Record<string, string> = {
        'unpaid': 'bg-slate-100 text-slate-800 dark:bg-slate-800 dark:text-slate-400 border-slate-200 dark:border-slate-700',
        'pending_verification': 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-400 border-yellow-200 dark:border-yellow-800',
        'verified': 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400 border-green-200 dark:border-green-800'
      };

      const paymentLabels: Record<string, string> = {
        'unpaid': 'Unpaid',
        'pending_verification': 'Pending Verification',
        'verified': 'Verified'
      };
      
      tbody.innerHTML += `
        <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors">
          <td class="p-4">
            <div class="font-medium text-slate-900 dark:text-white">${apt.customer_name}</div>
            <div class="text-xs text-slate-500 mt-1 flex flex-col gap-0.5">
              ${apt.customer_email ? `<span>✉️ ${apt.customer_email}</span>` : ''}
              ${apt.customer_phone ? `<span>📞 ${apt.customer_phone}</span>` : ''}
            </div>
          </td>
          <td class="p-4">
            <div class="font-medium text-slate-700 dark:text-slate-300">${apt.services?.name || 'Deleted Service'}</div>
            <div class="text-xs text-slate-500 mt-1">with ${apt.staff?.name || 'Any Available'}</div>
          </td>
          <td class="p-4">
            <div class="text-slate-900 dark:text-white">${apt.appointment_date ? new Date(apt.appointment_date).toLocaleDateString(undefined, { weekday: 'short', year: 'numeric', month: 'short', day: 'numeric' }) : 'TBD'}</div>
            <div class="text-sm text-slate-500 mt-1 font-medium">${apt.appointment_time || 'TBD'}</div>
          </td>
          <td class="p-4">
            <select 
              onchange="updateStatus('${apt.id}', this.value)"
              class="px-3 py-1 rounded-full text-xs font-medium border focus:outline-none cursor-pointer ${statusColors[apt.status]}"
            >
              <option value="pending" ${apt.status === 'pending' ? 'selected' : ''}>Pending</option>
              <option value="confirmed" ${apt.status === 'confirmed' ? 'selected' : ''}>Confirmed</option>
              <option value="completed" ${apt.status === 'completed' ? 'selected' : ''}>Completed</option>
              <option value="cancelled" ${apt.status === 'cancelled' ? 'selected' : ''}>Cancelled</option>
            </select>
          </td>
          <td class="p-4">
            <span class="px-3 py-1 rounded-full text-xs font-medium border inline-block ${paymentColors[apt.payment_status || 'unpaid']}">
              ${paymentLabels[apt.payment_status || 'unpaid']}
            </span>
          </td>
          <td class="p-4 text-right flex justify-end gap-2 items-center">
            ${apt.payment_status === 'pending_verification' ? `<button onclick="verifyPayment('${apt.id}')" class="p-1.5 text-green-600 hover:text-green-700 hover:bg-green-50 dark:hover:bg-green-900/30 rounded transition-colors" title="Verify Payment"><i data-lucide="check-circle" class="w-5 h-5"></i></button>` : ''}
            <button onclick="deleteAppointment('${apt.id}')" class="p-1.5 text-slate-400 hover:text-red-500 rounded transition-colors" title="Delete">
              <i data-lucide="trash-2" class="w-4 h-4"></i>
            </button>
          </td>
        </tr>
      `;
    });
    
    createIcons({ icons });
  }

  window.updateStatus = async (id: string, newStatus: string) => {
    try {
      const { error } = await supabase.from('appointments').update({ status: newStatus }).eq('id', id);
      if (error) throw error;
      window.showToast(`Status updated to ${newStatus}`, 'success');
      
      // Update local state instead of full refetch for snappy UI
      const apt = allAppointments.find(a => a.id === id);
      if (apt) apt.status = newStatus;
      applyFilters();
      
    } catch (err: any) {
      window.showToast(err.message, 'error');
      fetchAppointments(); // Revert UI
    }
  };

  window.deleteAppointment = async (id: string) => {
    if (!confirm('Are you sure you want to delete this appointment entirely?')) return;
    try {
      const { error } = await supabase.from('appointments').delete().eq('id', id);
      if (error) throw error;
      window.showToast('Appointment deleted', 'info');
      fetchAppointments();
    } catch (err: any) {
      window.showToast(err.message, 'error');
    }
  };

  window.verifyPayment = async (id: string) => {
    if (!confirm('Mark payment as verified and confirm booking?')) return;
    try {
      const { error } = await supabase.from('appointments').update({ 
        payment_status: 'verified',
        status: 'confirmed'
      }).eq('id', id);
      if (error) throw error;
      window.showToast('Payment verified and booking confirmed', 'success');
      
      const apt = allAppointments.find(a => a.id === id);
      if (apt) {
        apt.payment_status = 'verified';
        apt.status = 'confirmed';
      }
      applyFilters();
    } catch (err: any) {
      window.showToast(err.message, 'error');
    }
  };

  declare global {
    interface Window {
      updateStatus: (id: string, status: string) => void;
      deleteAppointment: (id: string) => void;
      verifyPayment: (id: string) => void;
    }
  }

  document.addEventListener('DOMContentLoaded', fetchAppointments);
</script>
